# ============================================
# AUTO-V .gitignore - Production Ready
# ============================================

# Dependencies
/node_modules
/.pnp
.pnp.js
.pnp.cjs
.pnp.loader.mjs

# Testing
/coverage
/.nyc_output
/.jest
/.vitest
/cypress
/.playwright

# Build outputs
/dist
/build
/.next
/out
/.output
/.nuxt
/.svelte-kit

# Environment variables
.env
.env.local
.env.*.local
.env.production
.env.development
.env.test
*.env

# Supabase
supabase/.temp
supabase/.env
.supabase

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
vite-debug.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
coverage
*.lcov

# nyc test coverage
.nyc_output

# Grunt intermediate storage (https://gruntjs.com/creating-plugins#storing-task-files)
.grunt

# Bower dependency directory (https://bower.io/)
bower_components

# node-waf configuration
.lock-wscript

# Compiled binary addons (https://nodejs.org/api/addons.html)
build/Release

# Dependency directories
jspm_packages/

# TypeScript cache
*.tsbuildinfo
.eslintcache

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# dotenv environment variables file
.env
.env.test
.env.production

# parcel-bundler cache (https://parceljs.org/)
.cache
.parcel-cache

# Next.js build output
.next
out

# Nuxt.js build / generate output
.nuxt
dist

# Gatsby files
.cache/
public

# Storybook build outputs
.storybook-out

# Temporary folders
tmp
temp
*.tmp
*.temp

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
.directory
*.sublime-*
.project
.classpath
.settings/

# OS generated files
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Uploads and user-generated content
/uploads
/user-uploads
/vehicle-photos
/inspection-photos
/certificate-pdfs
*.jpg
*.jpeg
*.png
*.gif
*.webp
*.svg
*.mp4
*.mov

# Backup files
*.bak
*.backup
*.old
*.orig

# Certificate files
*.pem
*.crt
*.key
*.p12

# Database files
*.sqlite
*.sqlite3
*.db
*.mdb
*.accdb

# Spreadsheets exports
*.xlsx
*.xls
*.csv
*.ods

# PDF exports
*.pdf

# Document uploads
/uploads/*
!.gitkeep

# Firebase
.firebase/
.firebaserc

# Exported environment variables file
.env.local
.env.production.local
.env.development.local
.env.test.local

# Vite
.vite

# Vitest
.vitest

# Vue
*.log
*.lock
*.pid
*.seed

# Webpack
.webpack

# Stencil
.stencil

# Cypress
cypress/videos/
cypress/screenshots/

# Playwright
test-results/
playwright-report/

# ESLint
.eslintcache

# Prettier
.prettiercache

# Turborepo
.turbo

# Netlify
.netlify

# Vercel
.vercel

# Cloudflare
.dev.vars
.vars

# Sentry
.sentry

# Diagnostic reports
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Local Netlify folder
.netlify

# Next.js
.next
out

# Nuxt
.nuxt
.nitro
.cache

# Output
dist
build

# Typescript
*.tsbuildinfo

# Optional: Keep specific files you want to track
!favicon.ico
