@app.post("/ocr/logbook")
def upload_logbook(vehicle_id: str, user_id: str, file: UploadFile = File(...)):

    os.makedirs("temp", exist_ok=True)

    file_path = f"temp/{file.filename}"

    with open(file_path, "wb") as buffer:
        shutil.copyfileobj(file.file, buffer)

    result = ocr_service.process_logbook(
        vehicle_id,
        user_id,
        file_path
    )

    os.remove(file_path)

    return result
